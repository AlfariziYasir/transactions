{
  "swagger": "2.0",
  "info": {
    "title": "Payment Service API",
    "description": "management payment service (Get, Tracking, History).",
    "version": "1.0"
  },
  "tags": [
    {
      "name": "PaymentService"
    }
  ],
  "consumes": [
    "application/json"
  ],
  "produces": [
    "application/json"
  ],
  "paths": {
    "/v1/payments": {
      "get": {
        "summary": "list payments by role",
        "description": "get list payments by role",
        "operationId": "PaymentService_List",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/v1ListPaymentsResponse"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "pageSize",
            "in": "query",
            "required": true,
            "type": "integer",
            "format": "int32"
          },
          {
            "name": "pageToken",
            "in": "query",
            "required": true,
            "type": "string"
          },
          {
            "name": "userId",
            "in": "query",
            "required": false,
            "type": "string"
          }
        ],
        "tags": [
          "payment"
        ]
      }
    },
    "/v1/payments/{paymentId}": {
      "get": {
        "summary": "get payment by id",
        "description": "get detail payment by id",
        "operationId": "PaymentService_GetPayment",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/v1GetPaymentResponse"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "paymentId",
            "in": "path",
            "required": true,
            "type": "string"
          }
        ],
        "tags": [
          "payment"
        ]
      }
    }
  },
  "definitions": {
    "protobufAny": {
      "type": "object",
      "properties": {
        "@type": {
          "type": "string"
        }
      },
      "additionalProperties": {}
    },
    "rpcStatus": {
      "type": "object",
      "properties": {
        "code": {
          "type": "integer",
          "format": "int32"
        },
        "message": {
          "type": "string"
        },
        "details": {
          "type": "array",
          "items": {
            "type": "object",
            "$ref": "#/definitions/protobufAny"
          }
        }
      }
    },
    "v1CreatePaymentResponse": {
      "type": "object",
      "properties": {
        "paymentId": {
          "type": "string"
        },
        "paymentUrl": {
          "type": "string"
        },
        "status": {
          "type": "string"
        }
      }
    },
    "v1GetPaymentResponse": {
      "type": "object",
      "properties": {
        "paymentId": {
          "type": "string"
        },
        "orderId": {
          "type": "string"
        },
        "userId": {
          "type": "string"
        },
        "amount": {
          "type": "string",
          "format": "int64"
        },
        "status": {
          "type": "string"
        },
        "method": {
          "type": "string"
        },
        "paidAt": {
          "type": "string"
        }
      }
    },
    "v1ListPaymentsResponse": {
      "type": "object",
      "properties": {
        "orders": {
          "type": "array",
          "items": {
            "type": "object",
            "$ref": "#/definitions/v1GetPaymentResponse"
          }
        },
        "nextPageToken": {
          "type": "string"
        },
        "totalCount": {
          "type": "integer",
          "format": "int32"
        }
      }
    }
  },
  "securityDefinitions": {
    "BearerAuth": {
      "type": "apiKey",
      "name": "Authorization",
      "in": "header"
    }
  },
  "security": [
